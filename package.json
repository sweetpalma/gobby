{
  "name": "gobby",
  "version": "0.1.0",
  "type": "module",
  "description": "Mischievous gremlin agent with goblin vibes.",
  "author": "SweetPalma",
  "license": "MIT",
  "keywords": [
    "agent",
    "ai",
    "llm"
  ],
  "bin": {
    "gobby": "dist/index.js"
  },
  "scripts": {
    "chat": "tsx src/index.ts",
    "build": "npm run typecheck && npm run bundle",
    "bundle": "esbuild src/index.ts  --outdir=dist --platform=node --packages=external --format=esm  --bundle",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/hub": "^2.13.1",
    "ansi-escapes": "^7.3.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^15.0.0",
    "es-toolkit": "^1.47.0",
    "is-online": "^12.0.2",
    "node-llama-cpp": "^3.18.1",
    "ora": "^9.4.0",
    "string-width": "^8.2.1",
    "terminal-size": "^4.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
