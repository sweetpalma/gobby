{
  "name": "gobby",
  "version": "0.1.0",
  "type": "module",
  "description": "Mischievous gremlin agent with goblin vibes.",
  "author": "SweetPalma",
  "license": "MIT",
  "keywords": [
    "agent",
    "ai",
    "llm"
  ],
  "bin": {
    "gobby": "dist/index.js"
  },
  "scripts": {
    "chat": "tsx src/index.ts",
    "build": "npm run typecheck && npm run bundle",
    "bundle": "esbuild src/index.ts  --outdir=dist --platform=node --packages=external --format=esm  --bundle",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@huggingface/hub": "^2.12.0",
    "node-llama-cpp": "^3.18.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}