{
	"name": "gobby-agent",
	"version": "0.1.5",
	"type": "module",
	"description": "Mischievous gremlin agent with goblin vibes.",
	"author": "SweetPalma",
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sweetpalma/gobby.git"
	},
	"bugs": {
		"url": "https://github.com/sweetpalma/gobby/issues"
	},
	"keywords": [
		"agent",
		"ai",
		"llm",
		"terminal",
		"cli"
	],
	"main": "dist/index.js",
	"files": [
		"dist"
	],
	"bin": {
		"gobby": "dist/index.js"
	},
	"scripts": {
		"prepack": "npm run build",
		"prepare": "husky",
		"chat": "tsx src/index.ts",
		"build": "npm run typecheck && npm run bundle",
		"bundle": "esbuild src/index.ts --outdir=dist --platform=node --packages=external --format=esm --bundle",
		"format-check": "prettier --check \"./**/*.{ts,md,yml,json}\"",
		"format": "prettier --write \"./**/*.{ts,md,yml,json}\"",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --mode=src",
		"test-watch": "vitest --mode=src --watch",
		"test-e2e": "vitest run --mode=e2e"
	},
	"dependencies": {
		"@commander-js/extra-typings": "^15.0.0",
		"@huggingface/hub": "^2.13.1",
		"@inkjs/ui": "^2.0.0",
		"commander": "^15.0.0",
		"diff-match-patch-ts": "^0.8.0",
		"es-toolkit": "^1.47.0",
		"fast-glob": "^3.3.3",
		"ink": "^7.0.6",
		"is-online": "^12.0.2",
		"marked": "^10.0.0",
		"marked-terminal": "^7.3.0",
		"node-llama-cpp": "^3.18.1",
		"react": "^19.2.7",
		"winston": "^3.19.0",
		"winston-daily-rotate-file": "^5.0.0",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/marked-terminal": "^6.1.1",
		"@types/node": "^25.9.3",
		"@types/react": "^19.2.17",
		"esbuild": "^0.28.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"memfs": "^4.57.8",
		"prettier": "^3.8.3",
		"string-comparison": "^1.3.0",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"allowScripts": {
		"esbuild": true,
		"fsevents": true,
		"node-llama-cpp": true
	},
	"lint-staged": {
		"**/*.{ts,md,yml,json}": "prettier --write"
	}
}
